Output docs/demo/tui-first-run.gif

Set Shell "zsh"
Set FontSize 18
Set Width 1400
Set Height 900

Type "udl tui"
Enter
Sleep 2s

Type " "
Sleep 500ms
Backspace
Sleep 500ms

Enter
Sleep 2s

Type "j"
Sleep 400ms
Type "j"
Sleep 400ms
Type "k"
Sleep 400ms

Enter
Sleep 2s

Type "j"
Sleep 500ms
Enter
Sleep 2s

Type "soundcloud-likes"
Enter
Sleep 1s

Type "j"
Enter
Sleep 2s

Type "https://soundcloud.com/your-user"
Enter
Sleep 1s

Type "j"
Enter
Sleep 2s

Type "s"
Sleep 3s
